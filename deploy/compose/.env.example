# =============================================================================
# CyberSiren — Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env in the same directory (deploy/compose/.env).
# These values are used by docker-compose.yml for infra services only.
#
# NOTE: This is separate from the repo-root .env.example which controls
# application-level config (CYBERSIREN_* vars). This file controls the
# Docker infrastructure (container ports, credentials, etc.).
# =============================================================================

# -- PostgreSQL ----------------------------------------------------------------
POSTGRES_DB=cybersiren
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# -- Valkey --------------------------------------------------------------------
VALKEY_PORT=6379

# -- Kafka ---------------------------------------------------------------------
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# -- pgAdmin -------------------------------------------------------------------
# Local dev only — never use this in production.
PGADMIN_PORT=5050
PGADMIN_PASSWORD=admin
