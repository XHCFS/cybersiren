        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(feed_sync_duration_seconds_bucket{service=\"svc-11-ti-sync\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(feed_sync_duration_seconds_bucket{service=\"svc-11-ti-sync\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
