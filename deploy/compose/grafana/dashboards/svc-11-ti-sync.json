  "panels": [
    {
      "title": "Feed Sync — Success Rate",
      "description": "Rate of successful feed sync cycles.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(feed_sync_total{service=\"svc-11-ti-sync\"}[5m])",
          "legendFormat": "syncs/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Feed Sync — Errors by Feed",
      "description": "Rate of sync errors partitioned by feed name.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(feed_sync_errors_total{service=\"svc-11-ti-sync\"}[5m])",
          "legendFormat": "{{feed_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Feed Sync — Duration (p50 / p95 / p99)",
      "description": "Histogram quantiles of end-to-end feed sync cycle duration.",
