        {
          "expr": "process_open_fds",
          "legendFormat": "open fds",
          "refId": "A"
        }
      ]
    },
    {
      "title": "TI Cache — Refresh Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ti_cache_refresh_duration_seconds_sum",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    }
