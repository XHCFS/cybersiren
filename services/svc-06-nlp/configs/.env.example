# =============================================================================
# CyberSiren SVC-06 (NLP Analysis) — Environment Variables
#
# Service-scoped reference for services/svc-06-nlp.
# Copy needed values into your deployment environment or root .env file.
# =============================================================================

# -- Runtime -------------------------------------------------------------------
CYBERSIREN_ENV=development
CYBERSIREN_LOG__LEVEL=debug
CYBERSIREN_LOG__PRETTY=true

# -- Required shared validation fields -----------------------------------------
# shared/config.Validate() requires db.* and auth.jwt_secret even for svc-06.
# This service does NOT connect to Postgres; these values only satisfy the validator.
CYBERSIREN_AUTH__JWT_SECRET=replace-with-a-long-random-secret
CYBERSIREN_DB__NAME=cybersiren
CYBERSIREN_DB__USER=cybersiren
CYBERSIREN_DB__PASSWORD=cybersiren

# -- Server --------------------------------------------------------------------
CYBERSIREN_SERVER__PORT=8086

# -- NLP backend (Python FastAPI inference service) ----------------------------
# In Docker: started by entrypoint.sh in the same container.
# For local development: start services/svc-06-nlp/nlp/app.py manually first.
CYBERSIREN_ML__NLP_SERVICE_URL=http://localhost:8001

# -- Observability (optional) --------------------------------------------------
CYBERSIREN_JAEGER_ENDPOINT=
CYBERSIREN_METRICS_PORT=9090
