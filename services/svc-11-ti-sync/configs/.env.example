# =============================================================================
# CyberSiren SVC-11 (TI Feed Sync) — Environment Variables
#
# Service-scoped reference for services/svc-11-ti-sync.
# Copy needed values into your deployment environment or root .env file.
# =============================================================================

# -- Runtime -------------------------------------------------------------------
CYBERSIREN_ENV=development
CYBERSIREN_LOG__LEVEL=info
CYBERSIREN_LOG__PRETTY=true
CYBERSIREN_SYNC_INTERVAL_SECONDS=3600

# -- Required shared validation fields -----------------------------------------
# shared/config.Validate() requires these values even for svc-11.
CYBERSIREN_AUTH__JWT_SECRET=replace-with-a-long-random-secret

# -- Postgres ------------------------------------------------------------------
CYBERSIREN_DB__HOST=localhost
CYBERSIREN_DB__PORT=5432
CYBERSIREN_DB__NAME=cybersiren
CYBERSIREN_DB__USER=cybersiren
CYBERSIREN_DB__PASSWORD=changeme
CYBERSIREN_DB__SSL_MODE=disable

# -- Valkey --------------------------------------------------------------------
CYBERSIREN_VALKEY__ADDR=localhost:6379
CYBERSIREN_VALKEY__DB=0
CYBERSIREN_VALKEY__PASSWORD=

# -- Observability --------------------------------------------------------------
CYBERSIREN_JAEGER_ENDPOINT=
CYBERSIREN_METRICS_PORT=9090

# -- Feed credentials -----------------------------------------------------------
# PhishTank requires API key registration: https://www.phishtank.com/
CYBERSIREN_FEED_PHISHTANK_API_KEY=

# OpenPhish public feed is non-commercial use only.
# API key is optional and only used for paid/private tiers.
CYBERSIREN_FEED_OPENPHISH_API_KEY=

# ThreatFox auth key is optional for public endpoint but recommended.
CYBERSIREN_FEED_THREATFOX_API_KEY=

# MalwareBazaar requires an API key: https://bazaar.abuse.ch/
# NOTE: query=get_recent returns only the last 60 minutes of samples.
# Set CYBERSIREN_SYNC_INTERVAL_SECONDS ≤ 3600 to avoid missing samples.
CYBERSIREN_FEED_MALWAREBAZAAR_API_KEY=

# -- Hash cache ----------------------------------------------------------------
# Hash cache TTL in seconds (default 7200). Should be ≥ sync interval.
CYBERSIREN_TI_HASH_CACHE_TTL_SECONDS=7200
