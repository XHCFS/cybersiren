# =============================================================================
# CyberSiren — Environment Configuration
# Copy this file to .env in the project root and fill in real values.
# Never commit .env to version control.
#
# Service-scoped .env examples live under services/*/configs/.env.example.
# This root file is the canonical superset for onboarding and local development.
#
# Mapping rules for koanf env loader:
# - Prefix: CYBERSIREN_
# - Double underscore (__) means nested key path levels
# - Single underscores remain part of field names
#
# Example mappings:
# - CYBERSIREN_DB__PASSWORD -> db.password
# - CYBERSIREN_AUTH__JWT_SECRET -> auth.jwt_secret
# - CYBERSIREN_SERVER__READ_TIMEOUT -> server.read_timeout
# =============================================================================

# -- Application ---------------------------------------------------------------
# Options: development | staging | production
CYBERSIREN_ENV=development

# -- Server --------------------------------------------------------------------
CYBERSIREN_SERVER__HOST=0.0.0.0
CYBERSIREN_SERVER__PORT=8080
CYBERSIREN_SERVER__READ_TIMEOUT=15s
CYBERSIREN_SERVER__WRITE_TIMEOUT=15s
CYBERSIREN_SERVER__IDLE_TIMEOUT=60s

# -- Database (Postgres + pgvector) --------------------------------------------
CYBERSIREN_DB__HOST=localhost
CYBERSIREN_DB__PORT=5432
CYBERSIREN_DB__NAME=cybersiren
CYBERSIREN_DB__USER=postgres
CYBERSIREN_DB__PASSWORD=postgres
# Options: disable | allow | prefer | require | verify-ca | verify-full
CYBERSIREN_DB__SSL_MODE=disable

# pgx pool
CYBERSIREN_DB__MAX_CONNS=20
CYBERSIREN_DB__MIN_CONNS=2
CYBERSIREN_DB__MAX_CONN_LIFETIME=1h
CYBERSIREN_DB__MAX_CONN_IDLE_TIME=30m
CYBERSIREN_DB__HEALTH_CHECK_PERIOD=1m

# -- Observability --------------------------------------------------------------
CYBERSIREN_JAEGER_ENDPOINT=
CYBERSIREN_METRICS_PORT=19090

# -- Cache / Valkey -------------------------------------------------------------
CYBERSIREN_VALKEY__ADDR=localhost:6379
CYBERSIREN_VALKEY__DB=0
CYBERSIREN_VALKEY__PASSWORD=

# -- Threat Intel Feed Sync (svc-11) -------------------------------------------
# Feed API keys
# Required if PhishTank feed is enabled in DB.
# Register for a key at https://www.phishtank.com/.
CYBERSIREN_FEED_PHISHTANK_API_KEY=

# OpenPhish free feed has non-commercial usage restrictions.
# Key remains optional and reserved for paid/API tiers.
CYBERSIREN_FEED_OPENPHISH_API_KEY=

# Used by ThreatFox feed client (optional for public endpoint)
CYBERSIREN_FEED_THREATFOX_API_KEY=

# URLhaus live feed uses a public CSV endpoint and does not require an API key.

# Sync cadence (seconds): default 21600 = 6h
CYBERSIREN_SYNC_INTERVAL_SECONDS=21600

# -- Live Feed Tests (only for tests) ------------------------------------------
# Set to 1 to run real upstream pulls in services/svc-11-ti-sync/tests/feeds_live_test.go
RUN_LIVE_FEED_TESTS=0

# -- Auth ----------------------------------------------------------------------
CYBERSIREN_AUTH__JWT_SECRET=replace-with-a-long-random-secret
CYBERSIREN_AUTH__JWT_EXPIRY=24h
# Increase to 14 in production
CYBERSIREN_AUTH__BCRYPT_COST=12
CYBERSIREN_AUTH__API_KEY_PREFIX=cs_
CYBERSIREN_AUTH__API_KEY_PREFIX_LEN=8

# -- Logging -------------------------------------------------------------------
# Options: debug | info | warn | error
CYBERSIREN_LOG__LEVEL=info
# Set to false in production
CYBERSIREN_LOG__PRETTY=true

# -- Worker --------------------------------------------------------------------
CYBERSIREN_WORKER__CONCURRENCY=10
CYBERSIREN_WORKER__QUEUE=default
CYBERSIREN_WORKER__MAX_RETRIES=3

# -- ML ------------------------------------------------------------------------
CYBERSIREN_ML__NLP_SERVICE_URL=http://localhost:8001
# Path is resolved relative to the process working directory.
# For native runs from the repo root, use the service path below.
CYBERSIREN_ML__URL_MODEL_PATH=./services/svc-03-url-analysis/ml/inference_script.py

# -- Enrichment pipeline --------------------------------------------------------
CYBERSIREN_ENRICHMENT__WORKER_COUNT=10
CYBERSIREN_ENRICHMENT__JOB_TIMEOUT=30s
CYBERSIREN_ENRICHMENT__MAX_RETRIES=3

# VirusTotal
CYBERSIREN_ENRICHMENT__VIRUSTOTAL__API_KEY=
CYBERSIREN_ENRICHMENT__VIRUSTOTAL__BASE_URL=https://www.virustotal.com/api/v3
CYBERSIREN_ENRICHMENT__VIRUSTOTAL__TIMEOUT=20s

# IPInfo
CYBERSIREN_ENRICHMENT__IPINFO__TOKEN=
CYBERSIREN_ENRICHMENT__IPINFO__BASE_URL=https://ipinfo.io
CYBERSIREN_ENRICHMENT__IPINFO__TIMEOUT=10s

# WHOIS XML API
CYBERSIREN_ENRICHMENT__WHOIS__API_KEY=
CYBERSIREN_ENRICHMENT__WHOIS__BASE_URL=https://www.whoisxmlapi.com/whoisserver/WhoisService
CYBERSIREN_ENRICHMENT__WHOIS__TIMEOUT=15s

# URLScan.io
CYBERSIREN_ENRICHMENT__URLSCAN__API_KEY=
CYBERSIREN_ENRICHMENT__URLSCAN__BASE_URL=https://urlscan.io/api/v1
CYBERSIREN_ENRICHMENT__URLSCAN__TIMEOUT=30s

# Screenshot service (self-hosted headless browser API, e.g. Playwright)
CYBERSIREN_ENRICHMENT__SCREENSHOT__ENDPOINT=http://localhost:3000/screenshot
CYBERSIREN_ENRICHMENT__SCREENSHOT__TIMEOUT=20s

# -- Object Storage (screenshots) ----------------------------------------------
# S3 or S3-compatible (MinIO, GCS interop, Cloudflare R2, etc.)
CYBERSIREN_STORAGE__BUCKET=cybersiren-screenshots
CYBERSIREN_STORAGE__REGION=us-east-1
CYBERSIREN_STORAGE__ACCESS_KEY=
CYBERSIREN_STORAGE__SECRET_KEY=
CYBERSIREN_STORAGE__ENDPOINT= # leave blank for AWS S3; set for MinIO/R2
CYBERSIREN_STORAGE__USE_SSL=true

# -- Embedding (pgvector) ------------------------------------------------------
# Must match vector(N) dimension in schema (default 1536 for text-embedding-3-small)
CYBERSIREN_EMBEDDING__PROVIDER=openai
CYBERSIREN_EMBEDDING__API_KEY=
CYBERSIREN_EMBEDDING__MODEL=text-embedding-3-small
CYBERSIREN_EMBEDDING__DIMENSION=1536
CYBERSIREN_EMBEDDING__BASE_URL=https://api.openai.com/v1
