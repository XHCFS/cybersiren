# =============================================================================
#  CyberSiren — Environment Configuration
#  Copy to .env and fill in values. Never commit .env to version control.
#  All variables are prefixed CYBERSIREN_.
#  These map to config.yaml keys: CYBERSIREN_DB_PASSWORD → db.password
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
CYBERSIREN_ENV=development          # development | staging | production

# ── Server ────────────────────────────────────────────────────────────────────
CYBERSIREN_SERVER_HOST=0.0.0.0
CYBERSIREN_SERVER_PORT=8080
CYBERSIREN_SERVER_READ_TIMEOUT=15s
CYBERSIREN_SERVER_WRITE_TIMEOUT=15s
CYBERSIREN_SERVER_IDLE_TIMEOUT=60s

# ── Database (Postgres + pgvector) ────────────────────────────────────────────
CYBERSIREN_DB_HOST=localhost
CYBERSIREN_DB_PORT=5432
CYBERSIREN_DB_NAME=cybersiren
CYBERSIREN_DB_USER=cybersiren
CYBERSIREN_DB_PASSWORD=changeme
CYBERSIREN_DB_SSL_MODE=disable      # disable | require | verify-full

# pgx connection pool — tune based on your instance size
CYBERSIREN_DB_MAX_CONNS=20
CYBERSIREN_DB_MIN_CONNS=2
CYBERSIREN_DB_MAX_CONN_LIFETIME=1h
CYBERSIREN_DB_MAX_CONN_IDLE_TIME=30m
CYBERSIREN_DB_HEALTH_CHECK_PERIOD=1m

# ── Auth ──────────────────────────────────────────────────────────────────────
CYBERSIREN_AUTH_JWT_SECRET=replace-with-a-long-random-secret
CYBERSIREN_AUTH_JWT_EXPIRY=24h
CYBERSIREN_AUTH_BCRYPT_COST=12      # increase to 14 in production
CYBERSIREN_AUTH_API_KEY_PREFIX=cs_
CYBERSIREN_AUTH_API_KEY_PREFIX_LEN=8

# ── Logging ───────────────────────────────────────────────────────────────────
CYBERSIREN_LOG_LEVEL=info           # debug | info | warn | error
CYBERSIREN_LOG_PRETTY=true          # true in development, false in production

# ── Enrichment pipeline ───────────────────────────────────────────────────────
CYBERSIREN_ENRICHMENT_WORKER_COUNT=10
CYBERSIREN_ENRICHMENT_JOB_TIMEOUT=30s
CYBERSIREN_ENRICHMENT_MAX_RETRIES=3

# VirusTotal
CYBERSIREN_ENRICHMENT_VIRUSTOTAL_API_KEY=
CYBERSIREN_ENRICHMENT_VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
CYBERSIREN_ENRICHMENT_VIRUSTOTAL_TIMEOUT=20s

# IPInfo
CYBERSIREN_ENRICHMENT_IPINFO_TOKEN=
CYBERSIREN_ENRICHMENT_IPINFO_BASE_URL=https://ipinfo.io
CYBERSIREN_ENRICHMENT_IPINFO_TIMEOUT=10s

# WHOIS XML API
CYBERSIREN_ENRICHMENT_WHOIS_API_KEY=
CYBERSIREN_ENRICHMENT_WHOIS_BASE_URL=https://www.whoisxmlapi.com/whoisserver/WhoisService
CYBERSIREN_ENRICHMENT_WHOIS_TIMEOUT=15s

# URLScan.io
CYBERSIREN_ENRICHMENT_URLSCAN_API_KEY=
CYBERSIREN_ENRICHMENT_URLSCAN_BASE_URL=https://urlscan.io/api/v1
CYBERSIREN_ENRICHMENT_URLSCAN_TIMEOUT=30s

# Screenshot service (self-hosted headless browser API, e.g. Playwright)
CYBERSIREN_ENRICHMENT_SCREENSHOT_ENDPOINT=http://localhost:3000/screenshot
CYBERSIREN_ENRICHMENT_SCREENSHOT_TIMEOUT=20s

# ── Object Storage (screenshots) ──────────────────────────────────────────────
# S3 or S3-compatible (MinIO, GCS interop, Cloudflare R2, etc.)
CYBERSIREN_STORAGE_BUCKET=cybersiren-screenshots
CYBERSIREN_STORAGE_REGION=us-east-1
CYBERSIREN_STORAGE_ACCESS_KEY=
CYBERSIREN_STORAGE_SECRET_KEY=
CYBERSIREN_STORAGE_ENDPOINT=        # leave blank for AWS S3; set for MinIO/R2
CYBERSIREN_STORAGE_USE_SSL=true

# ── Embedding (pgvector) ──────────────────────────────────────────────────────
# Must match vector(N) dimension in the schema (default 1536 for text-embedding-3-small)
CYBERSIREN_EMBEDDING_PROVIDER=openai
CYBERSIREN_EMBEDDING_API_KEY=
CYBERSIREN_EMBEDDING_MODEL=text-embedding-3-small
CYBERSIREN_EMBEDDING_DIMENSION=1536
CYBERSIREN_EMBEDDING_BASE_URL=https://api.openai.com/v1
