# =============================================================================
#  CyberSiren — Environment Configuration
#  Copy to .env and fill in values. Never commit .env to version control.
#  All variables are prefixed CYBERSIREN_.
#
#  Hierarchy delimiter: use DOUBLE underscores (__) to separate nested keys.
#  Single underscores are preserved as-is inside field names.
#
#  Examples:
#    CYBERSIREN_DB__PASSWORD      → db.password
#    CYBERSIREN_AUTH__JWT_SECRET   → auth.jwt_secret
#    CYBERSIREN_SERVER__READ_TIMEOUT → server.read_timeout
# =============================================================================

# -- Application ---------------------------------------------------------------
CYBERSIREN_ENV=development          # development | staging | production

# -- Server --------------------------------------------------------------------
CYBERSIREN_SERVER__HOST=0.0.0.0
CYBERSIREN_SERVER__PORT=8080
CYBERSIREN_SERVER__READ_TIMEOUT=15s
CYBERSIREN_SERVER__WRITE_TIMEOUT=15s
CYBERSIREN_SERVER__IDLE_TIMEOUT=60s

# -- Database (Postgres + pgvector) --------------------------------------------
CYBERSIREN_DB__HOST=localhost
CYBERSIREN_DB__PORT=5432
CYBERSIREN_DB__NAME=cybersiren
CYBERSIREN_DB__USER=cybersiren
CYBERSIREN_DB__PASSWORD=changeme
CYBERSIREN_DB__SSL_MODE=disable      # disable | require | verify-full

# pgx connection pool — tune based on your instance size
CYBERSIREN_DB__MAX_CONNS=20
CYBERSIREN_DB__MIN_CONNS=2
CYBERSIREN_DB__MAX_CONN_LIFETIME=1h
CYBERSIREN_DB__MAX_CONN_IDLE_TIME=30m
CYBERSIREN_DB__HEALTH_CHECK_PERIOD=1m

# -- Auth ----------------------------------------------------------------------
CYBERSIREN_AUTH__JWT_SECRET=replace-with-a-long-random-secret
CYBERSIREN_AUTH__JWT_EXPIRY=24h
CYBERSIREN_AUTH__BCRYPT_COST=12      # increase to 14 in production
CYBERSIREN_AUTH__API_KEY_PREFIX=cs_
CYBERSIREN_AUTH__API_KEY_PREFIX_LEN=8

# -- Logging -------------------------------------------------------------------
CYBERSIREN_LOG__LEVEL=info           # debug | info | warn | error
CYBERSIREN_LOG__PRETTY=true          # true in development, false in production

# -- Enrichment pipeline -------------------------------------------------------
CYBERSIREN_ENRICHMENT__WORKER_COUNT=10
CYBERSIREN_ENRICHMENT__JOB_TIMEOUT=30s
CYBERSIREN_ENRICHMENT__MAX_RETRIES=3

# VirusTotal
CYBERSIREN_ENRICHMENT__VIRUSTOTAL__API_KEY=
CYBERSIREN_ENRICHMENT__VIRUSTOTAL__BASE_URL=https://www.virustotal.com/api/v3
CYBERSIREN_ENRICHMENT__VIRUSTOTAL__TIMEOUT=20s

# IPInfo
CYBERSIREN_ENRICHMENT__IPINFO__TOKEN=
CYBERSIREN_ENRICHMENT__IPINFO__BASE_URL=https://ipinfo.io
CYBERSIREN_ENRICHMENT__IPINFO__TIMEOUT=10s

# WHOIS XML API
CYBERSIREN_ENRICHMENT__WHOIS__API_KEY=
CYBERSIREN_ENRICHMENT__WHOIS__BASE_URL=https://www.whoisxmlapi.com/whoisserver/WhoisService
CYBERSIREN_ENRICHMENT__WHOIS__TIMEOUT=15s

# URLScan.io
CYBERSIREN_ENRICHMENT__URLSCAN__API_KEY=
CYBERSIREN_ENRICHMENT__URLSCAN__BASE_URL=https://urlscan.io/api/v1
CYBERSIREN_ENRICHMENT__URLSCAN__TIMEOUT=30s

# Screenshot service (self-hosted headless browser API, e.g. Playwright)
CYBERSIREN_ENRICHMENT__SCREENSHOT__ENDPOINT=http://localhost:3000/screenshot
CYBERSIREN_ENRICHMENT__SCREENSHOT__TIMEOUT=20s

# -- Object Storage (screenshots) ----------------------------------------------
# S3 or S3-compatible (MinIO, GCS interop, Cloudflare R2, etc.)
CYBERSIREN_STORAGE__BUCKET=cybersiren-screenshots
CYBERSIREN_STORAGE__REGION=us-east-1
CYBERSIREN_STORAGE__ACCESS_KEY=
CYBERSIREN_STORAGE__SECRET_KEY=
CYBERSIREN_STORAGE__ENDPOINT=        # leave blank for AWS S3; set for MinIO/R2
CYBERSIREN_STORAGE__USE_SSL=true

# -- Embedding (pgvector) ------------------------------------------------------
# Must match vector(N) dimension in the schema (default 1536 for text-embedding-3-small)
CYBERSIREN_EMBEDDING__PROVIDER=openai
CYBERSIREN_EMBEDDING__API_KEY=
CYBERSIREN_EMBEDDING__MODEL=text-embedding-3-small
CYBERSIREN_EMBEDDING__DIMENSION=1536
CYBERSIREN_EMBEDDING__BASE_URL=https://api.openai.com/v1
